<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Modifier une réservation - Port Russell</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <nav>
      <a href="/dashboard">Tableau de bord</a>
      <a href="/catways">Catways</a>
      <a href="/users">Utilisateurs</a>
      <a href="/logout">Se déconnecter</a>
    </nav>

    <div class="container">
      <h1>Modifier la réservation</h1>

      <form
        action="/catways/<%= reservation.catwayNumber %>/reservations?_method=PUT"
        method="POST"
      >
        <input type="hidden" name="id" value="<%= reservation._id %>" />
        <div>
          <label for="clientName">Client</label>
          <input
            type="text"
            id="clientName"
            name="clientName"
            value="<%= reservation.clientName %>"
            required
          />
        </div>
        <div>
          <label for="boatName">Bateau</label>
          <input
            type="text"
            id="boatName"
            name="boatName"
            value="<%= reservation.boatName %>"
            required
          />
        </div>
        <div>
          <label for="startDate">Date de début</label>
          <input
            type="date"
            id="startDate"
            name="startDate"
            value="<%= new Date(reservation.startDate).toISOString().split('T')[0] %>"
            required
          />
        </div>
        <div>
          <label for="endDate">Date de fin</label>
          <input
            type="date"
            id="endDate"
            name="endDate"
            value="<%= new Date(reservation.endDate).toISOString().split('T')[0] %>"
            required
          />
        </div>
        <button type="submit">Modifier</button>
      </form>

      <a href="/catways/<%= reservation.catwayNumber %>/reservations">Retour</a>
    </div>
  </body>
</html>
