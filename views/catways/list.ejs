<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Catways - Port Russell</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <nav>
        <a href="/dashboard">Tableau de bord</a>
        <a href="/catways">Catways</a>
        <a href="/users">Utilisateurs</a>
        <a href="/logout">Se déconnecter</a>
    </nav>

    <div class="container">
        <h1>Gestion des catways</h1>

        <h2>Ajouter un catway</h2>
        <form action="/catways" method="POST">
            <div>
                <label for="catwayNumber">Numéro</label>
                <input type="number" id="catwayNumber" name="catwayNumber" required>
            </div>
            <div>
                <label for="catwayType">Type</label>
                <select id="catwayType" name="catwayType" required>
                    <option value="short">Short</option>
                    <option value="long">Long</option>
                </select>
            </div>
            <div>
                <label for="catwayState">État</label>
                <input type="text" id="catwayState" name="catwayState" required>
            </div>
            <button type="submit">Ajouter</button>
        </form>

        <h2>Liste des catways</h2>
        <table>
            <thead>
                <tr>
                    <th>Numéro</th>
                    <th>Type</th>
                    <th>État</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% catways.forEach(catway => { %>
                <tr>
                    <td><%= catway.catwayNumber %></td>
                    <td><%= catway.catwayType %></td>
                    <td><%= catway.catwayState %></td>
                    <td>
                        <a href="/catways/<%= catway.catwayNumber %>/reservations">Réservations</a>
                        <form action="/catways/<%= catway.catwayNumber %>?_method=DELETE" method="POST">
                            <button type="submit">Supprimer</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>